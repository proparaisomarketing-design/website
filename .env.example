# Copie este arquivo para .env.local e preencha com valores reais.
# NUNCA comite .env.local — ele está no .gitignore.

# Banco de dados SQLite (Prisma)
# Local (desenvolvimento): file:./dev.db (relativo a /prisma)
# Produção (Coolify): file:/data/inscricoes.db (volume persistente montado em /data)
DATABASE_URL="file:./dev.db"

# Chave da API OpenAI usada pelo chat do briefing (app/api/briefing/chat) — opcional
# Gere em: https://platform.openai.com/api-keys
OPENAI_API_KEY=
